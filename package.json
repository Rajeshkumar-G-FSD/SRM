{
  "name": "srm-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "next-app",
    "server"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:next": "npm --workspace next-app run dev",
    "dev:server": "npm --workspace server run dev",
    "build:frontend": "npm --workspace frontend run build",
    "build:next": "npm --workspace next-app run build",
    "build:server": "npm --workspace server run build"
  }
}
